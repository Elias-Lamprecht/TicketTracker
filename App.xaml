<Application x:Class="TicketTracker.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="ControlBgBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F1F1F1"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#A259FF"/>
    </Application.Resources>
</Application>