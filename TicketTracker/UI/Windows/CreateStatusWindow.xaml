<Window x:Class="TicketTracker.UI.Forms.CreateStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TicketTracker.UI.Forms"
        mc:Ignorable="d"
        Title="Create New Status" Height="300" Width="320"
        Background="{StaticResource WindowBgBrush}"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Title" Margin="0,0,0,5" Foreground="White" />
            <TextBox x:Name="TitleInput" Margin="0,0,0,15" />

            <TextBlock Text="Description" Margin="0,0,0,5" Foreground="White" />
            <TextBox x:Name="DescriptionInput" 
                     Height="80" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Width="70" Height="25" Margin="5,0" IsCancel="True"/>
            <Button Content="Create" Width="70" Height="25" 
                    Click="CreateStatus_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
